# Copy this file to .env and fill in your values.
#
# NOTE: The dashboard's Settings page (~/.race-engineer/config.json) is the
# primary surface for editing these values at runtime. The persisted file
# overrides .env. .env still works as a fallback for keys you haven't
# touched in the UI, and remains the easiest way to bootstrap a fresh
# install.

# LLM Provider configuration
LLM_PROVIDER="gemini"                  # "gemini" (default), "anthropic", "openai"
LLM_MODEL=""                           # Override model (empty = provider default)
GEMINI_API_KEY="your_api_key_here"     # Required when LLM_PROVIDER=gemini
ANTHROPIC_API_KEY=""                   # Required when LLM_PROVIDER=anthropic
OPENAI_API_KEY=""                      # Required when LLM_PROVIDER=openai

# Telemetry configuration
TELEMETRY_MODE="real"        # "real" = listen on UDP, "mock" = generate fake data
TELEMETRY_HOST="0.0.0.0"
TELEMETRY_PORT="20777"
UDP_MODE="broadcast"         # "broadcast" = game broadcasts to all, "unicast" = game sends to specific IP

# Go telemetry-core service (THE BRAIN)
API_PORT="8081"              # REST API port
DB_PATH="workspace/telemetry.duckdb"
BATCH_SIZE="20"              # DuckDB flush threshold
SAMPLE_RATE="20"             # 20Hz → 1Hz sampling
TALK_LEVEL="5"               # Insight verbosity (1-10)
LOG_LEVEL="info"             # Log level: trace, debug, info, warn, error, fatal, panic
WORKSPACE_DIR="workspace"    # Path to workspace/ directory with markdown context files

# WebSocket push rate (Hz). Higher = smoother dashboard, more bandwidth.
# 5=200ms, 10=100ms (default), 20=50ms (match UDP rate)
WS_PUSH_RATE="10"

# Push-to-talk via steering wheel button (F1 BUTN event bitmask).
#
# RECOMMENDED SETUP — UDP Action slots:
#   F1 25 has "UDP Action 1..8" bindings under Settings > Controls > UDP.
#   These bits fire through BUTN with NO in-game side-effect — perfect for
#   us. Bind one to a wheel button the driver doesn't otherwise use, run
#   `./workspace/bin/buttonprobe` to confirm the bitmask, and paste it here.
#   This combines the no-side-effect property of MFD with the precision of
#   a real button — closes the gap that the historic R2/RT mapping had.
#
# Bit layout (single-bit values — OR multiples to accept any of several):
#   0x00000001 = Cross / A           0x00010000 = Touchpad
#   0x00000002 = Triangle / Y        0x00020000 = UDP Action 1
#   0x00000004 = Circle / B          0x00040000 = UDP Action 2
#   0x00000008 = Square / X          0x00080000 = UDP Action 3
#   0x00000010 = D-pad Left          0x00100000 = UDP Action 4
#   0x00000020 = D-pad Right         0x00200000 = UDP Action 5
#   0x00000040 = D-pad Up            0x00400000 = UDP Action 6
#   0x00000080 = D-pad Down          0x00800000 = UDP Action 7
#   0x00000100 = Options / Menu      0x01000000 = UDP Action 8
#   0x00000200 = L1 / LB             0x00000800 = L2 / LT
#   0x00000400 = R1 / RB             0x00001000 = R2 / RT
#
# Default 0x00000001 = Cross/A on the observed PS5 telemetry stream. Set to
# 0 to disable single-button mode (e.g. when using PTT_TRIGGER=dual).
PTT_BUTTON="0x00000001"
# PTT_MODE: "hold"   = mic open while button held (momentary, default).
#           "toggle" = press once to open, press again to close (latched).
#                     Miss-tolerant — a dropped release event doesn't strand
#                     the mic; the next press always recovers.
# Recommended with single-bit button setups where missed releases are a risk.
PTT_MODE="hold"

# PTT_TRIGGER chooses which signal drives PTT:
#   "button" (default) — F1 BUTN events (60Hz polled by F1 — fast taps may miss)
#   "dual"             — two distinct buttons: one OPENS the mic, one CLOSES it.
#                        Press-edge only, so dropped releases can never strand
#                        the mic. Set PTT_BUTTON_START and PTT_BUTTON_END below.
#   "mfd"              — any MFDPanelIndex change in car_telemetry (60Hz snapshot,
#                        never misses; driver cycles MFD pages on the wheel)
# With "mfd" the driver's wheel must have an MFD-next/prev binding (most do).
# Each press = one PTT event. Side effect: MFD page advances, no driving impact.
PTT_TRIGGER="button"

# Two-button PTT (used only when PTT_TRIGGER="dual").
# Bind one UDP Action slot for OPEN, another for CLOSE — see PTT_BUTTON
# notes above for the bit table. Press-edge only, so missed releases are
# harmless. Most miss-tolerant configuration available.
PTT_BUTTON_START="0x00020000"   # UDP Action 1 — opens the mic
PTT_BUTTON_END="0x00040000"     # UDP Action 2 — closes the mic

# BUTN diagnostics (silent by default — only "PTT toggled ON/OFF" still
# logs in normal operation). Re-enable when identifying a new button.
#   BUTN_PROBE=true       → log every PRESS / RELEASE with hex + label
#   BUTN_PROBE_RAW=true   → log every BUTN packet, even no-change ones
#   BUTN_STATS_LOG=true   → emit a 30s summary line with rates + drop counts
#BUTN_PROBE="false"
#BUTN_PROBE_RAW="false"
#BUTN_STATS_LOG="false"

# Gemini Live PTT source (which gate drives gemini_live_service.py's mic):
#   "keyboard"   = follow GEMINI_LIVE_PTT_KEY (pynput, default)
#   "controller" = follow the F1 wheel/pad button (PTT_BUTTON + PTT_MODE) via WS
#   "off"        = always-hot mic
GEMINI_LIVE_PTT_SOURCE="keyboard"

# Voice input mode — which voice-input path runs at boot.
#   "live_only" (default) — only Gemini Live. STT not initialised,
#                            /api/voice returns 503. Saves an idle SDK
#                            client + ~tens of MB of resident memory.
#   "ptt_only"             — only the legacy push-to-talk path
#                            (STT → CommsGate → TTS). Gemini Live agent
#                            factory not built; /api/voice/live refuses.
#   "both"                 — both inputs wired. Live owns the audio
#                            output (TTS pipeline silenced). PTT input
#                            available as a fallback but its response is
#                            served through the brain context, not TTS.
# Empty falls back to legacy GEMINI_LIVE_ENABLED interpretation:
# GEMINI_LIVE_ENABLED=true → "both"; otherwise → "live_only".
VOICE_MODE="live_only"

# Python voice + transcription service
VOICE_URL="http://localhost:8000"  # Voice service URL for TTS + STT
VOICE_PORT="8000"                  # Port the voice service listens on
TTS_ENGINE="edge-tts"              # TTS backend: "edge-tts" (default), "qwen-tts" (MLX voice cloning)
TTS_VOICE="en-GB-RyanNeural"       # edge-tts voice (British male, fits F1 engineer)
TTS_VOICE_REF="workspace/voices/reference.wav"  # Voice reference WAV for qwen-tts cloning
TTS_SPEED="1.0"                    # Qwen TTS speech speed (1.0 = normal, 2.0 = 2x faster)
WHISPER_MODEL="medium"             # faster-whisper model size: tiny, base, small, medium, large-v3

# STT (Speech-to-Text) engine
STT_ENGINE="whisper"               # "whisper" = local faster-whisper, "parakeet" = NVIDIA NeMo, "resemble" = cloud API
RESEMBLE_API_KEY=""                # Resemble.ai API key (required when STT_ENGINE=resemble)
RESEMBLE_BASE_URL="https://app.resemble.ai/api/v2"  # Resemble API base URL

# Pi Agent — sandboxed background data-analyst team. Replaces the old
# in-process Strategy Analyst. The Go server hosts an MCP server at
# PI_AGENT_MCP_PATH; pi_agent_service.py is a Python child process whose
# only outward connection is that MCP endpoint.
PI_AGENT_MODE="off"                # "off" or "on" — start.sh launches pi_agent_service.py when on
PI_AGENT_PROVIDER="anthropic"      # "anthropic" | "gemini" | "openai"
PI_AGENT_MODEL=""                  # Optional override for planner model
PI_AGENT_SPECIALIST_MODEL=""       # Optional override for specialist sub-loops
PI_AGENT_MAX_PRIORITY="3"          # Cap on push_insight priority (1-5)
PI_AGENT_MCP_PATH="/mcp"           # HTTP path the MCP server is mounted on
PI_AGENT_TRIGGER_TIMEOUT_SEC="10"  # Long-poll timeout for pull_next_trigger

# Gemini Live conversational backend.
# Controlled by VOICE_MODE above; this legacy flag is only consulted when
# VOICE_MODE is empty (then GEMINI_LIVE_ENABLED=true maps to VOICE_MODE=both).
# Leave commented unless you need the legacy interpretation.
# GEMINI_LIVE_ENABLED="false"
GEMINI_LIVE_MODEL="gemini-3.1-flash-live-preview"      # Live API model
# GEMINI_LIVE_BRAIN_POLL_SEC was removed — brain is loaded once at session start
# and refreshed via the query_brain tool when the model decides it needs to.
GEMINI_LIVE_BRAIN_MAX_CHARS="8000"                     # Truncation cap for the initial brain snapshot
GEMINI_LIVE_ANALYST_TIMEOUT="120"                      # ask_data_analyst tool timeout (s)
RACE_API_URL="http://localhost:8081"                   # Base URL the live agent calls for tools
# MIC_INDEX=2                                          # Optional: skip the mic picker prompt
# Push-to-talk key. Empty = always-hot mic (simplest; may pick up ambient noise).
# Single char like "`" or pynput key name like "space"/"ctrl_r" enables hold-to-talk.
# macOS needs Accessibility permission for the terminal when PTT is enabled.
GEMINI_LIVE_PTT_KEY=""
# Session-opening prompt. Sent once per service lifetime (not on every reconnect).
# Empty string disables the proactive greeting.
# GEMINI_LIVE_OPENING_PROMPT="[SESSION START] Greet the driver with a brief radio check..."
